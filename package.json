{
  "name": "code-in-wechat",
  "version": "0.1.0",
  "description": "WeChat bot that forwards messages between WeChat and AI coding tools (OpenCode)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "start": "bun dist/index.js"
  },
  "dependencies": {
    "@opencode-ai/sdk": "latest",
    "dotenv": "^16.4.5",
    "hono": "^4.4.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
