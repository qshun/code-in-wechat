# ============================================
# code-in-wechat 环境变量配置
# ============================================

# ---- iLink API 配置 ----
ILINK_BASE_URL=https://ilinkai.weixin.qq.com

# ---- OpenCode Server 配置 ----
# OpenCode 服务端口（容器内默认 4096）
OPENCODE_PORT=4096
# Docker 环境下使用 host.docker.internal 访问宿主机服务
# 本地开发使用 127.0.0.1
OPENCODE_HOSTNAME=127.0.0.1
# AI 模型，格式: provider/model
OPENCODE_MODEL=opencode-go/kimi-k2.6
# OpenCode 工作目录，Docker 环境建议设为 /workspace
OPENCODE_DIRECTORY=/path/to/your/project

# Tool Configuration
WORK_SPACE_DIR=/path/to/your/project

# Default tool to use , e.g., opencode, claude, codex
DEFAULT_TOOL=opencode

# Claude AI Configuration
CLAUDE_SETTINGS_PATH=~/.claude/settings.json

# Codex CLI Configuration
CODEX_PATH=codex

# ---- Web Server 配置 ----
SERVER_PORT=3000
# Docker 环境必须设为 0.0.0.0 才能从外部访问
SERVER_HOST=localhost

# ---- 日志级别 ----
# 可选: debug | info | warn | error
LOG_LEVEL=info

# ---- Bot Token 存储 ----
# Docker 环境下映射到 /data/bot-token.json
BOT_TOKEN_PATH=./bot-token.json

# ---- 会话数据库 ----
# Docker 环境下映射到 /data/session-db.json
SESSION_DB_PATH=./session-db.json

# ---- Docker Compose 专用 ----
# 宿主机项目目录挂载到容器 /workspace
# WORKSPACE_DIR=./workspace

# ============================================
# Docker 快速启动:
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 修改 .env 中的配置（至少设置 OPENCODE_MODEL 和 OPENCODE_DIRECTORY）
#   3. Docker 环境: OPENCODE_HOSTNAME=host.docker.internal, SERVER_HOST=0.0.0.0
#   4. 启动: docker compose up -d
#   5. 首次启动需扫码登录，查看日志: docker compose logs -f
# ============================================
